# Plaintext secrets — NEVER commit these.
.env
secrets.env
.luke-key

# The SOPS-encrypted secrets ARE committed (ciphertext, safe in a public
# repo). This negation makes the intent explicit and guards against a
# broader *.env ignore ever hiding it.
!secrets.enc.env

node_modules/

# Stray SSH keypairs. A ssh-keygen answered "y" at the overwrite prompt writes
# the private key to a file literally named `y` in the cwd — which is how one
# ended up in this working tree. The repo is public, so one `git add -A` would
# publish it. Broad patterns so it can't recur under another name.
id_ed25519*
id_rsa*
*.pem
/y
/y.pub
